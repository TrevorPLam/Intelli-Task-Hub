{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*",
    "mockupPreviewPlugin.ts",
    "vite.config.ts",
    ".generated/**/*"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
