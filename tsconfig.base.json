/**
 * TypeScript Base Configuration
 *
 * T-18 TypeScript Strictness Uplift - COMPLETED
 *
 * Changes made:
 * - Enabled noUnusedLocals: true for catching unused variables
 * - Enabled strictFunctionTypes: true for stricter function type checking
 * - strictPropertyInitialization: true was already enabled
 *
 * Generated files are excluded in package-specific tsconfigs to prevent
 * breaking changes to auto-generated code from Orval.
 *
 * @see https://www.typescriptlang.org/tsconfig#noUnusedLocals
 * @see https://www.typescriptlang.org/tsconfig#strictFunctionTypes
 */
{
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": false,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "alwaysStrict": true,
    "skipLibCheck": true,
    "target": "es2022",
    "types": [],
    "customConditions": ["workspace"]
  }
}
