{
  "name": "@workspace/integrations-openai-ai-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./audio": "./src/audio/index.ts"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.11.0",
    "@types/react": "catalog:",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-playwright": "^1.6.0",
    "prettier": "^3.2.0",
    "react": "catalog:",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0",
    "@vitest/ui": "^1.3.0",
    "jsdom": "^24.0.0"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,json,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,json,md}",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "serve:test": "npx http-server src/__tests__/playwright -p 3000 --cors",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps",
    "performance:test": "playwright test --grep=\"Performance\"",
    "analyze:performance": "node scripts/analyze-performance.js"
  }
}
