{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["dom", "es2022", "webworker"],
    "jsx": "react-jsx"
  },
  "include": ["src/**/*"],
  "exclude": [
    "src/audio/**/*",
    "src/__tests__/**/*",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
