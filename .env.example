# Intelli-Task-Hub Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files with real secrets to version control

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/intellitaskhub

# Database Connection Pool Settings (2026 Best Practices)
# Maximum connections in pool (rule: max(4 × CPU cores, 100))
# Default: 20 (suitable for most chat application workloads)
# DB_POOL_MAX=20

# Idle connection timeout in milliseconds (release idle connections quickly)
# Default: 30000 (30 seconds)
# DB_POOL_IDLE_TIMEOUT_MS=30000

# Connection timeout in milliseconds (fail fast on connection issues)
# Default: 5000 (5 seconds)
# DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Slow query threshold for performance monitoring
# Queries exceeding this duration will be logged as slow
# Default: 100 (milliseconds)
# DB_SLOW_QUERY_THRESHOLD_MS=100

# =============================================================================
# API Security
# =============================================================================
# Secret key for API authentication (JWT signing, API key validation)
# Minimum 32 characters required
# Generate with: openssl rand -base64 32
API_SECRET_KEY=your-minimum-32-character-secret-key-here

# =============================================================================
# OpenAI Integration
# =============================================================================
# OpenAI API key for AI features (chat, image generation, audio)
# Get from: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI base URL (for Azure OpenAI or proxies)
# Default: https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI model configuration
# Default chat model: gpt-4
# AI_INTEGRATIONS_OPENAI_CHAT_MODEL=gpt-4

# Default image generation model: dall-e-3
# AI_INTEGRATIONS_OPENAI_IMAGE_MODEL=dall-e-3

# Default audio transcription model: whisper-1
# AI_INTEGRATIONS_OPENAI_AUDIO_MODEL=whisper-1

# OpenAI request configuration
# Maximum completion tokens (1-128000, default: 4096)
# AI_INTEGRATIONS_OPENAI_MAX_TOKENS=4096

# Temperature for requests (0.0-2.0, default: 0.7)
# Higher values = more creative, lower values = more deterministic
# AI_INTEGRATIONS_OPENAI_TEMPERATURE=0.7

# Request timeout in milliseconds (min 1000, default: 30000)
# AI_INTEGRATIONS_OPENAI_TIMEOUT_MS=30000

# Rate limiting configuration
# Requests per minute (min 1, default: 60)
# AI_INTEGRATIONS_OPENAI_RATE_LIMIT_RPM=60

# Tokens per minute (min 1000, default: 100000)
# AI_INTEGRATIONS_OPENAI_RATE_LIMIT_TPM=100000

# Feature flags
# Enable streaming responses for chat (default: true)
# AI_INTEGRATIONS_OPENAI_ENABLE_STREAMING=true

# Enable image generation features (default: true)
# AI_INTEGRATIONS_OPENAI_ENABLE_IMAGES=true

# Enable audio transcription features (default: true)
# AI_INTEGRATIONS_OPENAI_ENABLE_AUDIO=true

# Optional organization and project configuration
# OpenAI organization ID for team accounts
# AI_INTEGRATIONS_OPENAI_ORG_ID=org-your-org-id

# OpenAI project ID for usage tracking
# AI_INTEGRATIONS_OPENAI_PROJECT_ID=proj_your-project-id

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for CORS
# Example: https://app.example.com,https://admin.example.com
# Development: http://localhost:3000,http://localhost:8081
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# =============================================================================
# Server Configuration
# =============================================================================
# Port for the API server to listen on
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# Rate Limiting (Optional - uses defaults if not set)
# =============================================================================
# General API rate limit window in milliseconds (default: 15 minutes)
# RATE_LIMIT_GENERAL_WINDOW_MS=900000

# General API max requests per window (default: 100)
# RATE_LIMIT_GENERAL_MAX=100

# OpenAI endpoint rate limit window in milliseconds (default: 1 minute)
# RATE_LIMIT_OPENAI_WINDOW_MS=60000

# OpenAI endpoint max requests per window (default: 20)
# RATE_LIMIT_OPENAI_MAX=20

# =============================================================================
# Mobile App Configuration (Expo/React Native)
# =============================================================================
# Public API URL accessible from mobile app
# Used at build time - cannot change at runtime
EXPO_PUBLIC_API_URL=http://localhost:3000

# App origin for deep linking/universal links
# EXPO_PUBLIC_APP_ORIGIN=https://localhost

# API key for mobile app authentication
# Must match API_SECRET_KEY for validation
EXPO_PUBLIC_API_KEY=your-minimum-32-character-secret-key-here

# =============================================================================
# Test Database Configuration (for automated testing)
# =============================================================================
# Test database URL - automatically configured in CI/CD
# Uses separate PostgreSQL instance for test isolation
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5433/intellitaskhub_test

# =============================================================================
# Replit-Specific (only needed when deploying to Replit)
# =============================================================================
# These are automatically set by Replit environment
# REPL_ID=your-repl-id
# REPLIT_EXPO_DEV_DOMAIN=your-repl-name.your-username.repl.co
# REPLIT_DEV_DOMAIN=your-repl-name.your-username.repl.co
# BASE_PATH=/

# Enable Replit-specific plugins in mockup-sandbox (development only)
# Set to "true" to enable cartographer plugin for Replit environment
# ENABLE_REPLIT_PLUGINS=true
